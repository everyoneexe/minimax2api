# MiniMax2API Configuration
# This is a REVERSE-ENGINEERED web interface proxy, NOT an official API client
# It uses browser automation to access agent.minimax.io (web UI), not the official API

# Server port
PORT=8000

# Default model for requests
DEFAULT_MODEL=MiniMax-M3

# Comma-separated proxy API keys that clients use to access this proxy
PROXY_API_KEYS=sk-default

# Lazy mode (browser-based sessions) - enabled by default
LAZY_SESSION=true

# Max concurrent requests (20 accounts × 5 concurrent = 100)
MAX_CONCURRENT_REQUESTS=100

# ═══════════════════════════════════════════════════════════════
# For multi-account support, add accounts via the WebUI at
# http://localhost:<PORT>/admin/ or edit config.json manually.
#
# Accounts use email/password authentication (not API keys)
# This system reverse-engineers the web interface at agent.minimax.io
# ═══════════════════════════════════════════════════════════════
